# API-Sports (api-sports.io) — register at https://api-sports.io
API_SPORTS_KEY=your_api_sports_key_here

# API-Football (apifootball.com) — register at https://apifootball.com
API_FOOTBALL_KEY=your_api_football_key_here

# Season to fetch (e.g. 2023 = 2023/24 season)
SEASON=2023

# Premier League ID per API
API_SPORTS_LEAGUE_ID=39
API_FOOTBALL_LEAGUE_ID=152
